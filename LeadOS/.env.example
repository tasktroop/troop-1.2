# Base Configurations
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# Auth & Database (Phase 1)
SUPABASE_URL=           # Your Supabase project URL (e.g. https://xyz.supabase.co)
SUPABASE_ANON_KEY=      # Supabase Anon Key for unauthenticated client interactions
SUPABASE_SERVICE_ROLE_KEY= # Supabase absolute bypass key for robust backend modifications natively

# LLM Orchestrator (Phase 3)
OPENAI_API_KEY=         # Your active OpenAI Organization sk-... bounds

# Payment Gateway (Phase 4)
RAZORPAY_KEY_ID=        # Razorpay Public API Identifier targeting Checkout UI
RAZORPAY_KEY_SECRET=    # Razorpay Webhook Verifier Secret

# Communications (Phase 4)
TWILIO_ACCOUNT_SID=     # Twilio SID bound to main tenant
TWILIO_AUTH_TOKEN=      # Twilio generic Auth Token globally used for signature verifications
TWILIO_WHATSAPP_NUMBER= # Designated number i.e whatsapp:+14155238886

# Social Schedulers (Phase 4)
BUFFER_ACCESS_TOKEN=    # OAuth2 generic access payload for Buffer updates/create

# Monitoring (Phase 5)
SENTRY_DSN=             # Sentry ingest trace URI
LOGFLARE_API_KEY=       # Logflare streaming API Key securely parsing logging outputs
